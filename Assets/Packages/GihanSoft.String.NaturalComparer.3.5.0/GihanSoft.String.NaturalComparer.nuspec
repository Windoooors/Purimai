  <metadata>
    <id>GihanSoft.String.NaturalComparer</id>
    <version>3.5.0</version>
    <title>GihanSoft Natural String Comparer</title>
    <authors>Muhammad Babayi</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
