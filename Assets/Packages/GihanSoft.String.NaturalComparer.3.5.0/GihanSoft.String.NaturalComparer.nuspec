    <releaseNotes>3.5.0:
      - enhanced by removing allocations</releaseNotes>
    <copyright>Copyright (c) 2022 Mohammad Babayi</copyright>
    <tags>string, comparer, IComparer, NaturalComparer, NaturalStringComparer, Natural-Sort, NaturalSort, String-Comparison, StringComparer, Sorting, Sort, Natural, csharp, c-sharp, C#,</tags>
    <repository type="git" url="https://github.com/GihanSoft/NaturalStringComparer" commit="db26c9492431a6e71755945a7d6e05a678cf8046" />
    <dependencies>
