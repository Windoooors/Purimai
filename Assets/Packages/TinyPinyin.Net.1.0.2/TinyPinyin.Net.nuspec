<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>TinyPinyin.Net</id>
    <version>1.0.2</version>
    <authors>TinyPinyin</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectUrl>https://github.com/hueifeng/TinyPinyin.Net</projectUrl>
    <description>适用于.Net平台的快速、低内存占用的汉字转拼音库。核心算法来自TinyPinyin(https://github.com/promeG/TinyPinyin)</description>
    <repository url="https://github.com/hueifeng/TinyPinyin.Net" />
    <dependencies>
      <group targetFramework=".NETFramework4.6.1" />
      <group targetFramework="net5.0" />
      <group targetFramework=".NETStandard2.0" />
    </dependencies>
  </metadata>
</package>