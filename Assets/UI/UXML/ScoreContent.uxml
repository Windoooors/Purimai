<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="score-content-background" style="flex-grow: 1; position: absolute; width: 205px; height: 178px; background-image: url(&quot;project://database/Assets/Sprite/UI/ScoreContentBackground.png?fileID=2800000&amp;guid=273ce83fea6a24214b8237014319d713&amp;type=3#ScoreContentBackground&quot;); -unity-background-image-tint-color: rgb(255, 255, 255); align-items: flex-end; justify-content: space-around; top: auto; left: auto; transition-property: color, -unity-background-image-tint-color, opacity; transition-duration: 0.2s, 0.2s, 0s;">
