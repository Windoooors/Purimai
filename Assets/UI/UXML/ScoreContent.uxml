            <ui:Label text="100.1111%" name="achievement-label" style="position: absolute; top: 16px; left: 15px; font-size: 24px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/LibreBaskerville/LibreBaskerville-Regular-2.ttf?fileID=12800000&amp;guid=5004f49d686ab4499ad40c876c8a9fe2&amp;type=3#LibreBaskerville-Regular-2&quot;);" />
