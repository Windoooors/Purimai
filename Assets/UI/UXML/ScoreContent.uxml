            <ui:Label text="F.A. 100.11%" name="sub-achievement-label" style="position: absolute; -unity-font-definition: url(&quot;project://database/Assets/Fonts/LibreBaskerville/LibreBaskerville-Regular-2.ttf?fileID=12800000&amp;guid=5004f49d686ab4499ad40c876c8a9fe2&amp;type=3#LibreBaskerville-Regular-2&quot;); font-size: 18px; top: 40px; left: 16px; bottom: 102px;" />
